# Google OAuth - https://console.cloud.google.com adresinden alın
# Credentials > OAuth 2.0 Client IDs > Web application
# Authorized redirect URIs: http://localhost:5175
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# Google Analytics 4 - https://analytics.google.com adresinden alın
# Admin > Data Streams > Web > Measurement ID (G-XXXXXXXXXX formatında)
VITE_GA_ID=G-XXXXXXXXXX
